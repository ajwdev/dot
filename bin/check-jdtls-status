#!/usr/bin/env bash
# Check jdtls status and workspace

PROJECT_DIR="${1:-$HOME/src/github.netflix.net/corp/tn-nftitus}"
PROJECT_NAME=$(basename "$PROJECT_DIR")
WORKSPACE_DIR="$HOME/.local/share/eclipse/$PROJECT_NAME"

echo "🔍 Checking jdtls status for $PROJECT_NAME"
echo ""

# Check workspace directory
if [ -d "$WORKSPACE_DIR" ]; then
    echo "✓ Workspace exists: $WORKSPACE_DIR"

    # Check for .metadata directory (indicates jdtls initialized)
    if [ -d "$WORKSPACE_DIR/.metadata" ]; then
        echo "✓ Workspace metadata exists (jdtls has initialized)"

        # Check for build state
        if [ -f "$WORKSPACE_DIR/.metadata/.plugins/org.eclipse.jdt.core/savedIndexNames.txt" ]; then
            echo "✓ Project index exists"
        else
            echo "⚠ Project index not found - project may not be fully imported"
        fi

        # Check log for errors
        if [ -f "$WORKSPACE_DIR/.metadata/.log" ]; then
            echo ""
            echo "Recent errors in jdtls log:"
            tail -20 "$WORKSPACE_DIR/.metadata/.log" | grep -i "error\|exception" || echo "  No recent errors found"
        fi
    else
        echo "⚠ No metadata directory - jdtls hasn't fully initialized yet"
    fi

    # Show workspace size
    SIZE=$(du -sh "$WORKSPACE_DIR" 2>/dev/null | cut -f1)
    echo ""
    echo "Workspace size: $SIZE"
else
    echo "✗ No workspace directory found at $WORKSPACE_DIR"
    echo "  jdtls hasn't been started yet for this project"
fi

echo ""
echo "📊 Project status:"
cd "$PROJECT_DIR" || exit 1

# Check if gradle has been run
if [ -d "build" ] || [ -d ".gradle" ]; then
    echo "✓ Gradle has been run (build artifacts exist)"
else
    echo "⚠ Gradle build artifacts not found"
    echo "  Run: cd $PROJECT_DIR && ./gradlew build -x test"
fi

# Check for .classpath (eclipse project files)
if [ -f ".classpath" ] || [ -f ".project" ]; then
    echo "✓ Eclipse project files exist"
else
    echo "⚠ No Eclipse project files (.classpath, .project)"
    echo "  These are generated by jdtls on first import"
fi

echo ""
echo "💡 Recommendations:"
if [ ! -d "$WORKSPACE_DIR/.metadata" ]; then
    echo "  1. Wait 30-60 seconds for jdtls to fully initialize"
    echo "  2. Check :LspInfo in Neovim to see initialization progress"
fi

if [ ! -d ".gradle" ]; then
    echo "  1. Run: ./gradlew build -x test"
    echo "  2. Then restart Neovim"
fi

if [ -d "$WORKSPACE_DIR" ] && [ ! -f ".classpath" ]; then
    echo "  1. Project import may have failed - check :LspLog in Neovim"
    echo "  2. Try: rm -rf $WORKSPACE_DIR && restart Neovim"
fi
